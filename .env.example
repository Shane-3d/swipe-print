# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in what you need.
# The app boots with the seed feed and (once MySQL is up) full accounts/sharing.
# All provider keys are OPTIONAL — unconfigured sources just contribute nothing.
# ----------------------------------------------------------------------------

# --- Database (Laravel Herd's MySQL defaults shown) -------------------------
# In Herd, MySQL runs on 127.0.0.1:3306 as root with an empty password.
# The app auto-creates the database + tables on first run.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=swipe_print

# --- Auth -------------------------------------------------------------------
# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET=dev-change-me-to-a-long-random-string

# --- Source providers (all optional) ----------------------------------------
# Thingiverse — free token: https://www.thingiverse.com/developers/apps
THINGIVERSE_TOKEN=

# Printables — unofficial public GraphQL; set to 1 to enable (no key).
PRINTABLES_ENABLED=

# MyMiniFactory — request a key: https://www.myminifactory.com/settings/developer
MYMINIFACTORY_KEY=

# Cults3D — create API credentials in your account: https://cults3d.com/en/api
CULTS3D_USER=
CULTS3D_KEY=

# Thangs — request API access: https://thangs.com (developer/partner program)
THANGS_KEY=
